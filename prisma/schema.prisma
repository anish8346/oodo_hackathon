generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String             @id @default(cuid())
  firstName         String
  lastName          String
  name              String?
  email             String             @unique
  phone             String?
  city              String?
  country           String?
  additionalInfo    String?
  image             String?
  password          String?
  emailVerified     DateTime?
  language          String             @default("en")
  preferredCurrency String             @default("INR")
  isAdmin           Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  ownedTrips        Trip[]             @relation("TripOwner")
  memberships       TripMember[]
  notes             TripNote[]
  savedDestinations SavedDestination[]
}

model Trip {
  id              String             @id @default(cuid())
  ownerId         String
  owner           User               @relation("TripOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  startDate       DateTime?
  endDate         DateTime?
  coverImageUrl   String?
  status          String             @default("planning")
  visibility      String             @default("private")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  members         TripMember[]
  stops           TripStop[]
  budget          TripBudget?
  checklist       PackingChecklist[]
  notes           TripNote[]
  sharedItinerary SharedItinerary?

  @@index([ownerId])
  @@map("TraveloopTrip")
}

model TripMember {
  id       String   @id @default(cuid())
  tripId   String
  userId   String
  role     String   @default("viewer")
  joinedAt DateTime @default(now())
  trip     Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@index([userId])
  @@map("TraveloopTripMember")
}

model City {
  id              String             @id @default(cuid())
  name            String
  country         String
  region          String?
  latitude        Float?
  longitude       Float?
  costIndex       Float              @default(1)
  popularityScore Int                @default(0)
  imageUrl        String?
  description     String?
  activities      CityActivity[]
  stops           TripStop[]
  savedBy         SavedDestination[]

  @@index([name])
  @@index([region])
  @@map("TraveloopCity")
}

model TripStop {
  id            String         @id @default(cuid())
  tripId        String
  cityId        String
  stopOrder     Int
  arrivalDate   DateTime?
  departureDate DateTime?
  notes         String?
  trip          Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  city          City           @relation(fields: [cityId], references: [id])
  activities    StopActivity[]
  budgetItems   BudgetItem[]
  tripNotes     TripNote[]

  @@index([tripId])
  @@index([cityId])
  @@map("TraveloopTripStop")
}

model CityActivity {
  id              String         @id @default(cuid())
  cityId          String
  title           String
  description     String?
  category        String?
  imageUrl        String?
  estimatedCost   Decimal        @default(0) @db.Decimal(10, 2)
  currency        String         @default("INR")
  durationMinutes Int?
  avgRating       Float?
  isPopular       Boolean        @default(false)
  city            City           @relation(fields: [cityId], references: [id], onDelete: Cascade)
  stopActivities  StopActivity[]

  @@index([cityId])
  @@map("TraveloopCityActivity")
}

model StopActivity {
  id             String       @id @default(cuid())
  stopId         String
  cityActivityId String
  activityDate   DateTime?
  startTime      String?
  endTime        String?
  actualCost     Decimal?     @db.Decimal(10, 2)
  status         String       @default("planned")
  sortOrder      Int          @default(0)
  notes          String?
  stop           TripStop     @relation(fields: [stopId], references: [id], onDelete: Cascade)
  cityActivity   CityActivity @relation(fields: [cityActivityId], references: [id])

  @@index([stopId])
  @@index([cityActivityId])
  @@map("TraveloopStopActivity")
}

model TripBudget {
  id              String       @id @default(cuid())
  tripId          String       @unique
  totalBudget     Decimal      @default(0) @db.Decimal(10, 2)
  estimatedTotal  Decimal      @default(0) @db.Decimal(10, 2)
  actualSpent     Decimal      @default(0) @db.Decimal(10, 2)
  currency        String       @default("INR")
  overBudgetAlert Boolean      @default(false)
  trip            Trip         @relation(fields: [tripId], references: [id], onDelete: Cascade)
  items           BudgetItem[]

  @@map("TraveloopTripBudget")
}

model BudgetItem {
  id              String     @id @default(cuid())
  budgetId        String
  stopId          String?
  category        String
  label           String?
  estimatedAmount Decimal    @default(0) @db.Decimal(10, 2)
  actualAmount    Decimal    @default(0) @db.Decimal(10, 2)
  currency        String     @default("INR")
  itemDate        DateTime?
  budget          TripBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  stop            TripStop?  @relation(fields: [stopId], references: [id], onDelete: SetNull)

  @@index([budgetId])
  @@index([stopId])
  @@map("TraveloopBudgetItem")
}

model PackingChecklist {
  id        String   @id @default(cuid())
  tripId    String
  itemName  String
  category  String   @default("other")
  isPacked  Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@map("TraveloopPackingChecklist")
}

model TripNote {
  id        String    @id @default(cuid())
  tripId    String
  userId    String
  stopId    String?
  title     String?
  content   String?
  noteDate  DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  trip      Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stop      TripStop? @relation(fields: [stopId], references: [id], onDelete: SetNull)

  @@index([tripId])
  @@index([userId])
  @@index([stopId])
  @@map("TraveloopTripNote")
}

model SharedItinerary {
  id         String    @id @default(cuid())
  tripId     String    @unique
  publicSlug String    @unique
  isActive   Boolean   @default(true)
  viewCount  Int       @default(0)
  copyCount  Int       @default(0)
  sharedAt   DateTime  @default(now())
  expiresAt  DateTime?
  trip       Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("TraveloopSharedItinerary")
}

model SavedDestination {
  id      String   @id @default(cuid())
  userId  String
  cityId  String
  savedAt DateTime @default(now())
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  city    City     @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([userId, cityId])
  @@index([cityId])
  @@map("TraveloopSavedDestination")
}
